# ──────────────────────────────────────────────────────────────
# Plant Monitoring ETL — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Google Sheets ──────────────────────────────────────────────
# The long ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE

# Name of the tab inside the spreadsheet
SHEET_NAME=Sheet1

# Path to your downloaded service-account JSON key
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json

# ── SQL Server ─────────────────────────────────────────────────
SQL_SERVER_HOST=localhost          # Use 'sqlserver' when running in Docker
SQL_SERVER_PORT=1433
SQL_SERVER_DATABASE=PlantMonitoring
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=YourStrong!Passw0rd   # Must meet SQL Server complexity rules

# ── ETL ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
